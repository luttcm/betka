PORT=3000

POSTGRES_DB=bet_mvp
POSTGRES_USER=bet_user
POSTGRES_PASSWORD=bet_password
POSTGRES_PORT=5432

REDIS_PORT=6379

# Optional DSN overrides for local run outside Docker.
# In Docker Compose these are composed automatically from variables above.
DATABASE_URL=postgresql://bet_user:bet_password@localhost:5432/bet_mvp?sslmode=disable
REDIS_URL=redis://localhost:6379
