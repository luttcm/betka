PORT=3000
AUTH_JWT_SECRET=dev-secret
AUTH_TOKEN_TTL=24h

POSTGRES_DB=bet_mvp
POSTGRES_USER=bet_user
POSTGRES_PASSWORD=bet_password
POSTGRES_PORT=5432

REDIS_PORT=6379

# Optional DSN overrides for local run outside Docker.
# In Docker Compose these are composed automatically from variables above.
DATABASE_URL=postgresql://bet_user:bet_password@localhost:5432/bet_mvp?sslmode=disable
REDIS_URL=redis://localhost:6379

# Email/SMTP config. If SMTP_HOST/SMTP_PORT are empty, backend uses log stub sender.
EMAIL_FROM=noreply@bet.local
EMAIL_VERIFY_BASE_URL=http://localhost:3000/v1/auth/verify-email
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
